# ============================================================
# CareChoice Demo — Environment Variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ============================================================

# --- Payload & Database ---
# Neon Postgres connection string. Format:
#   postgres://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=postgres://user:pass@host.neon.tech/carechoice?sslmode=require

# Random 32+ char string for Payload session encryption. Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-with-32-char-random-hex

# Public URL of the deployed site (used by Payload for media URLs, links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Salesforce UAT ---
# OAuth 2.0 Client Credentials flow against the Salesforce UAT sandbox.
# Set up a Connected App in Salesforce UAT with these scopes:
#   - api (read SDA Site records, write Lead/Case)
#   - refresh_token, offline_access
# Then enable "Client Credentials Flow" and assign an integration user.
SALESFORCE_INSTANCE_URL=https://carechoice--uat.sandbox.my.salesforce.com
SALESFORCE_CLIENT_ID=your-connected-app-consumer-key
SALESFORCE_CLIENT_SECRET=your-connected-app-consumer-secret
SALESFORCE_API_VERSION=60.0
